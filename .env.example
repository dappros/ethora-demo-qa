# Ethora Demo + QA harness — environment template.
# Copy to .env and fill in. NOTHING here is committed (see .gitignore).
# The harness can also provision a fresh world for you (npm run provision),
# in which case it writes the resulting credentials to secrets/world.json
# (gitignored) and you do not need to set the APP_* / OWNER_* values by hand.

# --- Target server ---------------------------------------------------------
# Which Ethora cluster to target. Default: qa
ETHORA_ENV=qa                                    # qa | prod

# Derived automatically from ETHORA_ENV, override only for self-hosted:
# ETHORA_API_BASE_URL=https://api.chat-qa.ethora.com/v1
# ETHORA_XMPP_WS=wss://xmpp.chat-qa.ethora.com/ws
# ETHORA_XMPP_HOST=xmpp.chat-qa.ethora.com
# ETHORA_XMPP_CONFERENCE=conference.xmpp.chat-qa.ethora.com

# --- Provisioning owner account -------------------------------------------
# The harness creates a throwaway tenant/owner account on first provision and
# stores its credentials in secrets/world.json. Set these only if you want to
# reuse a specific account instead of auto-creating one.
# OWNER_EMAIL=
# OWNER_PASSWORD=

# --- Local component checkouts (defaults assume sibling repos under product/) ---
WEB_COMPONENT_PATH=../ethora-chat-component
RN_COMPONENT_PATH=../ethora-chat-component-rn

# --- iOS simulator ---------------------------------------------------------
IOS_SIMULATOR=iPhone 16
